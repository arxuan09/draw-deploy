# ============================================================================
# drawnext 部署配置（.env）
#   推荐用一键脚本 deploy.sh 自动生成本文件并填好密钥；也可手动复制：
#       cp .env.example .env
# 说明：
#   - 数据库 / 缓存（MySQL、Redis）的配置已写死在 docker-compose.yml 内，这里不涉及。
#   - 站点信息 / 对象存储 / 邮件 / 支付 / AI 等业务配置登录后台「系统设置」里填。
#   - 本文件只放：登录密钥、后台加密密钥、授权码、端口。
# ============================================================================

# JWT 登录态签名密钥。deploy.sh 会自动生成。
JWT_SECRET=

# 后台密钥（对象存储 / AI / 支付 / 邮件）落库加密密钥。deploy.sh 会自动生成。
# ⚠️ 设置一次后【切勿更改】！改了之后后台已保存的密钥将无法解密，需全部重填。
SETTINGS_ENCRYPTION_KEY=

# 商业授权码（向供应商获取）。deploy.sh 会提示输入。
# 留空也能启动，但所有功能会被拦截、无法使用。
LICENSE_KEY=

# ===== 可选 =====

# 对外暴露的端口（宿主机侧 -> 容器 3000）
APP_PORT=16789

# 登录态有效期（天）
JWT_EXPIRES_DAYS=30
